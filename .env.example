# Vite public path: `/` for domain root (default if unset). For GitHub Pages project site use repo name, e.g. VITE_BASE_PATH=/DentMetric
# VITE_BASE_PATH=

# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# API (Supabase Edge Functions)
VITE_API_BASE_URL=https://YOUR_PROJECT.supabase.co/functions/v1

# Anonymous analytics / admin stats API (dev: Vite proxies /api → localhost:3001)
VITE_TRACKING_URL=/api

# Telegram bot username (for payment return URL)
VITE_BOT_USERNAME=your_bot_username

# Support bot/channel for the "Support" button in profile
VITE_SUPPORT_USERNAME=DentMetricSupport

# ─── BACKEND-ONLY secrets (НЕ VITE_ префикс — никогда в клиентском коде) ───
TELEGRAM_BOT_TOKEN=your_bot_token
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# YooKassa credentials — ONLY on backend, NEVER in frontend code.
# Frontend calls YOUR backend API; backend calls YooKassa with these.
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_WEBHOOK_SECRET=your_webhook_secret
