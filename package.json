{
  "name": "dentmetric",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx server/index.ts",
    "server:dev": "nodemon --watch server --exec tsx server/index.ts",
    "build": "vite build",
    "build:gh-pages": "vite build --mode github-pages",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "preview": "vite preview",
    "deploy:setup": "node scripts/deploy.js setup",
    "deploy": "node scripts/deploy.js deploy",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "konva": "^10.2.0",
    "pdfmake": "^0.3.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pdfmake": "^0.3.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.0.0",
    "nodemon": "^3.0.3",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.12"
  }
}
